# DevHub n8n — Environment Variables
# Kopieer naar .env en vul echte waarden in: cp .env.example .env
# NOOIT .env committen (Art. 8 Dataminimalisatie)

# PostgreSQL (n8n database)
N8N_POSTGRES_PASSWORD=change_me_to_strong_password

# n8n Basic Auth
N8N_USER=admin
N8N_PASSWORD=change_me_to_strong_password

# GitHub PAT (needs repo scope for issue creation)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Gmail App Password (voor RED-severity email notificaties)
# Maak aan via: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
